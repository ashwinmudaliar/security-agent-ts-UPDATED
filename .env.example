# Required by upgraded/agent.ts (CLI mode)
ANTHROPIC_API_KEY=your-key-here

# Additional vars required by webhook-server/server.ts
# Fine-grained PAT — Pull requests: read & write, Contents: read
GITHUB_TOKEN=ghp_your_pat_here
# HMAC secret — generate with `openssl rand -hex 32`
GITHUB_WEBHOOK_SECRET=your-random-32-byte-hex-string
# Optional, default 3000
PORT=3000

# smee.io channel URL — used by `npm run dev` to forward GitHub webhook
# deliveries to localhost. Get one at https://smee.io/new
SMEE_URL=https://smee.io/your-channel-here
